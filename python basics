        "def Trafficadvisor(color: str)->str:\n",
        "    if color ==\"red\":\n",
        "      return \"stop\"\n",
        "    elif color ==\"yellow\":\n",
        "      return \"Slow down\"\n",
        "    elif color ==\"green\":\n",
        "      return \"go\"\n",
        "    else:\n",
        "      return \"wait for the response\"\n",
        "print (Trafficadvisor(\"yellow\"))\n",
        "\n",
        "#------------MATCH CASE ------#\n",
        "def Trafficadvisor(color: str)->str:\n",
        "  match color:\n",
        "    case \"red\" :return \"stop\"\n",
        "    case \"yellow\":return \"slow down\"\n",
        "    case \"green\" :return \"go\"\n",
        "    case _: return \"wait for the response\"\n",
        "print (Trafficadvisor(\"red\"))\n",
        "\n",
        "#number sign classifier ----positive,negative,zero#\n",
        "def numclassifier(num : int)->str:\n",
        "  if num >0:\n",
        "    return \"positive\"\n",
        "  elif num <0:\n",
        "    return \"negative\"\n",
        "  else:\n",
        "    return \"zero\"\n",
        "print(numclassifier(-25))\n",
        "\n",
        "#terinary operator#\n",
        "def numclassifier(num : int)->str:\n",
        "  return \"zero\" if num==0 else(\"positive\" if num>0 else \"negative\")\n",
        "print(numclassifier(25))\n",
        "\n",
